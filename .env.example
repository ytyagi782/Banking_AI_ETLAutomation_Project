# Copy this file to ".env" and fill in the real values.
#
# 1) EMAIL (used by reporting_engine/email_report.py)
# Gmail requires a 16-character App Password (NOT your normal password).
# Create one at: Google Account -> Security -> 2-Step Verification -> App passwords
EMAIL_APP_PASSWORD=your_16_char_app_password_here

# 2) CLAUDE API (used by the agents/ package - the AI agents)
# Get a key at: https://console.anthropic.com/  -> API Keys
# The agents read this key automatically via python-dotenv.
ANTHROPIC_API_KEY=sk-ant-your_key_here
